diff --git a/debian/cargo-checksum.json b/debian/cargo-checksum.json
new file mode 100644
index 0000000..b5623be
--- /dev/null
+++ b/debian/cargo-checksum.json
@@ -0,0 +1 @@
+{"package":"Could not get crate checksum","files":{}}
diff --git a/debian/cargo_config b/debian/cargo_config
new file mode 100644
index 0000000..38bd089
--- /dev/null
+++ b/debian/cargo_config
@@ -0,0 +1,2 @@
+[build]
+rustflags = []
diff --git a/debian/compat b/debian/compat
new file mode 100644
index 0000000..48082f7
--- /dev/null
+++ b/debian/compat
@@ -0,0 +1 @@
+12
diff --git a/debian/control b/debian/control
index 51879f3..5fa3d9a 100644
--- a/debian/control
+++ b/debian/control
@@ -2,15 +2,15 @@ Source: rust-proxmox-websocket-tunnel
 Section: admin
 Priority: optional
 Build-Depends: debhelper (>= 12),
- dh-cargo,
+ dh-cargo (>= 25),
  cargo:native,
  rustc:native,
  libstd-rust-dev,
- libstd-rust-dev
 Maintainer: Proxmox Support Team <support@proxmox.com>
-Standards-Version: 4.5.1
+Standards-Version: 4.6.1
 Vcs-Git: git://git.proxmox.com/git/proxmox-websocket-tunnel.git
 Vcs-Browser: https://git.proxmox.com/?p=proxmox-websocket-tunnel.git
+X-Cargo-Crate: proxmox-websocket-tunnel
 Rules-Requires-Root: no
 
 Package: proxmox-websocket-tunnel
diff --git a/debian/rules b/debian/rules
new file mode 100755
index 0000000..f04a897
--- /dev/null
+++ b/debian/rules
@@ -0,0 +1,10 @@
+#!/usr/bin/make -f
+%:
+	dh $@ --buildsystem cargo
+
+override_dh_auto_configure:
+	mkdir -p debian/cargo_home/
+	cp -av debian/cargo_config debian/cargo_home/config
+
+override_dh_auto_test:
+	dh_auto_test -- test --all
diff --git a/debian/source/format b/debian/source/format
new file mode 100644
index 0000000..163aaf8
--- /dev/null
+++ b/debian/source/format
@@ -0,0 +1 @@
