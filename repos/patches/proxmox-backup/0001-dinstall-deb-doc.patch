From: Kamil Trzcinski <ayufan@ayufan.eu>
Date: Fri, 4 Jul 2025 09:06:39 +0200
Subject: [PATCH] dinstall deb doc

---
 Makefile | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/Makefile b/Makefile
index 6435262f..6818ac43 100644
--- a/Makefile
+++ b/Makefile
@@ -149,7 +149,7 @@ clean-deb:
 	rm -f *.deb *.dsc *.tar.* *.buildinfo *.build *.changes
 
 .PHONY: dinstall
-dinstall: $(SERVER_DEB) $(SERVER_DBG_DEB) $(CLIENT_DEB) $(CLIENT_DBG_DEB)
+dinstall: $(SERVER_DEB) $(SERVER_DBG_DEB) $(CLIENT_DEB) $(CLIENT_DBG_DEB) $(DOC_DEB)
 	dpkg -i $^
 
 # make sure we build binaries before docs
