ARG ARCH=
ARG IMAGE=${ARCH}debian:bookworm
FROM ${IMAGE} AS release_env
RUN apt-get -y update

ADD /release* /release/
RUN /release/install

RUN systemctl mask console-getty.service \
                   ssh.service \
                   postfix.service

VOLUME /persist \
  /var/lib/vz

ADD /dockerfiles/scripts/start.bash /start
ENTRYPOINT ["/start"]
